nasa_coding_guardrails:
  schema_version: "1.0"
  name: "NASA-derived software coding guardrails"
  status: "agent-readable distillation; not a substitute for project-specific NASA compliance approval"
  retrieved_at: "2026-04-28"

  authority_model:
    binding_status:
      - "Use NPR_7150_2D and NASA_STD_8739_8B as the authoritative NASA requirement/assurance sources."
      - "Use NASA_SWEHB guidance as implementation guidance unless project-specific direction overrides it."
      - "Use JPL_POWER_OF_TEN as public JPL-authored safety-critical C guidance, not as a standalone NASA procedural requirement."
      - "Do not claim NASA compliance unless the project has a selected standard, project applicability mapping, tailoring/waiver records, and required evidence."
    tailoring:
      required_for_deviation: true
      required_fields:
        - "rule_id"
        - "deviation"
        - "technical_rationale"
        - "risk_assessment"
        - "compensating_controls"
        - "approver"
        - "expiration_or_review_date"

  sources:
    NPR_7150_2D:
      title: "NASA Software Engineering Requirements"
      type: "NASA Procedural Requirements"
      url: "https://nodis3.gsfc.nasa.gov/displayDir.cfm?Internal_ID=N_PR_7150_002D_&page_name=Chapter4"
      relevant_sections:
        - "4.4.3 / SWE-061: select, define, and adhere to coding methods, standards, and criteria"
        - "4.4.4 / SWE-135: use static analysis tools for defects, security, code coverage, and complexity"
        - "4.4.5 / SWE-062: unit test software code"
        - "4.4.6 / SWE-186: assure repeatable unit-test results"

    NASA_STD_8739_8B:
      title: "Software Assurance and Software Safety Standard"
      type: "NASA Technical Standard"
      url: "https://standards.nasa.gov/sites/default/files/standards/NASA/B/0/NASA-STD-87398-Revision-B.pdf"
      relevant_sections:
        - "3.11.6 / SWE-207: identify, record, and implement secure coding practices"
        - "3.11.7 / SWE-185: verify code meets secure coding standard using static analysis results"
        - "4.4.3 / SWE-061: assure selection/definition and analyze conformance"
        - "4.4.4 / SWE-135: confirm static-analysis use and closure of results"

    NASA_SWEHB_CODING_STANDARDS:
      title: "NASA Software Engineering Handbook, 9.03 Coding Standards"
      type: "NASA Office of the Chief Engineer handbook guidance"
      url: "https://swehb.nasa.gov/spaces/SWEHBVC/pages/84279577/9.03+Coding+Standards"
      relevant_guidance:
        - "Implement a secure coding standard on mission-critical software"
        - "Use concise, relevant, automatable standards"
        - "High-reliability standards commonly restrict dynamic memory, complex flow control, recursion, scope, unchecked inputs, and unchecked returns"
        - "NASA-specific JPL/GSFC coding standards are in SPAN for NASA users"

    NASA_SWEHB_SWE_961:
      title: "NASA Software Engineering Handbook, SWE-961 Coding Standards - Guidance"
      type: "NASA Office of the Chief Engineer handbook guidance"
      url: "https://swehb.nasa.gov/spaces/SITE/pages/172851840/SWE-961+Coding+Standards+-+Guidance"
      relevant_guidance:
        - "Coding standards reduce errors, improve readability, maintainability, security, and testability"
        - "Standards should address code structure, error handling, module size, library routines, constants/data types, global data, compiler-specific features, formatting, naming, and comments"
        - "Static analyzers and compiler warnings should be used to verify adherence"

    JPL_POWER_OF_TEN:
      title: "The Power of Ten - Rules for Developing Safety Critical Code"
      type: "JPL-authored public safety-critical C guidance"
      url: "https://spinroot.com/gerard/pdf/P10.pdf"
      relevant_guidance:
        - "Ten safety-critical coding rules targeting analyzability and verification of C code"

  applicability_profiles:
    mission_critical_or_safety_critical:
      default_severity: "error"
      enforce_rule_sets:
        - "NASA_REQUIREMENTS"
        - "NASA_SECURE_CODING"
        - "NASA_SWEHB_MINIMAL_HIGH_RELIABILITY"
        - "JPL_POWER_OF_TEN_C_STRICT"
      deviation_policy: "explicit waiver required"

    nasa_general_software:
      default_severity: "error_for_requirements_warn_for_guidance"
      enforce_rule_sets:
        - "NASA_REQUIREMENTS"
        - "NASA_SECURE_CODING"
        - "NASA_SWEHB_GENERAL_STANDARD_CONTENT"
      deviation_policy: "documented project tailoring required"

    non_nasa_general_software:
      default_severity: "advisory"
      enforce_rule_sets:
        - "NASA_SWEHB_GENERAL_STANDARD_CONTENT"
        - "NASA_SWEHB_MINIMAL_HIGH_RELIABILITY"
      deviation_policy: "document rationale when relaxing safety-critical rules"

  agent_behavior:
    before_writing_or_modifying_code:
      - "Determine whether the code is safety-critical, mission-critical, security-sensitive, embedded, real-time, flight, ground, test-only, or general application code."
      - "Locate the project coding standard. Prefer repository files such as STANDARD.md, CONTRIBUTING.md, lint/static-analysis configs, compiler flags, and waiver logs."
      - "If no standard exists, create or propose a project-local coding standard profile before making broad code changes."
      - "Never state that code is NASA-compliant unless required evidence exists."

    during_code_generation:
      - "Prefer simple, statically analyzable constructs."
      - "Avoid introducing exceptions to any active guardrail."
      - "When a guardrail cannot be met, stop or mark the change as requiring waiver."
      - "Preserve traceability between requirement, code, test, static-analysis result, and waiver where applicable."

    before_delivery:
      - "Run or request compiler warnings, linters, static analysis, unit tests, coverage, and complexity checks appropriate to the language and profile."
      - "Report remaining violations as nonconformances unless waived."
      - "Do not suppress warnings without rationale and approval."

  rule_sets:
    NASA_REQUIREMENTS:
      - id: "NASA-SWE061"
        title: "Select, define, and adhere to coding methods, standards, and criteria"
        level: "must"
        applies_to: ["all_project_code"]
        source_refs: ["NPR_7150_2D#4.4.3", "NASA_STD_8739_8B#4.4.3"]
        agent_checks:
          - "project_has_declared_coding_standard"
          - "language_specific_rules_are_defined"
          - "tooling_for_conformance_is_defined"
          - "code_changes_conform_to_declared_standard"
        required_evidence:
          - "coding_standard_document"
          - "coding_standard_version"
          - "language/tool applicability"
          - "waiver_log_for_exceptions"
        failure_action: "block_or_request_project_standard"

      - id: "NASA-SWE135"
        title: "Use static analysis during development and testing"
        level: "must"
        applies_to: ["source_code", "generated_code", "modified_code"]
        source_refs: ["NPR_7150_2D#4.4.4", "NASA_STD_8739_8B#4.4.4"]
        agent_checks:
          - "static_analysis_config_exists"
          - "security_checkers_enabled"
          - "coding_error_checkers_enabled"
          - "complexity_metrics_collected"
          - "coverage_metrics_collected_where_applicable"
          - "findings_tracked_to_closure_or_waiver"
        required_evidence:
          - "static_analysis_report"
          - "security_scan_report"
          - "complexity_report"
          - "coverage_report_or_applicability_note"
          - "finding_disposition_log"
        failure_action: "block_release_for_unresolved_error_findings"

      - id: "NASA-SWE062"
        title: "Unit test software code"
        level: "must"
        applies_to: ["implemented_code"]
        source_refs: ["NPR_7150_2D#4.4.5", "NASA_STD_8739_8B#4.4.5"]
        agent_checks:
          - "unit_tests_exist_for_new_or_changed_logic"
          - "safety_critical_functions_have_direct_tests"
          - "boundary_and_off_nominal_cases_are_tested"
        required_evidence:
          - "unit_test_results"
          - "test_procedure_or_script"
          - "defect_log_for_failures"
        failure_action: "block_release_or_mark_untested"

      - id: "NASA-SWE186"
        title: "Assure repeatable unit-test results"
        level: "must"
        applies_to: ["unit_tests", "test_data", "test_scripts"]
        source_refs: ["NPR_7150_2D#4.4.6", "NASA_STD_8739_8B#4.4.6"]
        agent_checks:
          - "tests_are_deterministic_or_variance_is_explained"
          - "test_inputs_are_versioned"
          - "test_environment_is_documented"
        required_evidence:
          - "as_run_test_logs"
          - "test_data_version"
          - "test_environment_record"
        failure_action: "block_acceptance_of_unrepeatable_tests"

    NASA_SECURE_CODING:
      - id: "NASA-SWE207"
        title: "Identify, record, and implement secure coding practices"
        level: "must"
        applies_to: ["all_code_with_security_relevance"]
        source_refs: ["NASA_STD_8739_8B#3.11.6"]
        agent_checks:
          - "coding_standard_includes_secure_coding_practices"
          - "security_risks_are_linked_to_code_controls"
          - "unsafe_input_handling_is_rejected"
          - "unsafe_authentication_authorization_patterns_are_rejected"
          - "unsafe_memory_or_resource_handling_is_rejected"
        required_evidence:
          - "secure_coding_section"
          - "security_requirements_trace"
          - "secure_coding_review_results"
        failure_action: "block_or_request_secure_coding_standard"

      - id: "NASA-SWE185"
        title: "Verify secure coding standard conformance using static analysis"
        level: "must"
        applies_to: ["security_relevant_source_code"]
        source_refs: ["NASA_STD_8739_8B#3.11.7"]
        agent_checks:
          - "static_analysis_security_rules_enabled"
          - "findings_are_resolved_or_waived"
          - "waivers_include_security_risk_rationale"
        required_evidence:
          - "secure_static_analysis_report"
          - "finding_closure_records"
        failure_action: "block_release_for_unresolved_security_findings"

    NASA_SWEHB_GENERAL_STANDARD_CONTENT:
      - id: "NASA-SWEHB-CONTENT"
        title: "Coding standard content baseline"
        level: "should"
        applies_to: ["project_coding_standard"]
        source_refs: ["NASA_SWEHB_SWE_961#3.2"]
        required_topics:
          - "code_structure"
          - "error_handling"
          - "module_size_limits"
          - "library_routine_policy"
          - "operating_system_routine_policy"
          - "commercial_library_policy"
          - "project_utility_routine_policy"
          - "constants_and_data_types"
          - "global_data_policy"
          - "compiler_specific_feature_policy"
          - "formatting"
          - "naming_conventions"
          - "comments"
        failure_action: "request_completion_of_coding_standard"

      - id: "NASA-SWEHB-TOOLABLE"
        title: "Standards must be concise, relevant, and automatable"
        level: "should"
        applies_to: ["project_coding_standard", "review_process"]
        source_refs: ["NASA_SWEHB_CODING_STANDARDS#9.03", "NASA_SWEHB_SWE_961#3.3"]
        agent_checks:
          - "rules_are_short_enough_for_daily_use"
          - "rules_are_mapped_to_tools_where_possible"
          - "manual_review_rules_have_checklists"
        failure_action: "mark_standard_as_low_verifiability"

    NASA_SWEHB_MINIMAL_HIGH_RELIABILITY:
      - id: "NASA-HR-001"
        title: "Restrict dynamic memory allocation"
        level: "should_for_high_reliability; must_for_safety_critical_profile"
        applies_to: ["runtime_code"]
        source_refs: ["NASA_SWEHB_CODING_STANDARDS#minimal_set", "JPL_POWER_OF_TEN#rule_3"]
        rule: "Do not allocate/free heap memory after initialization in safety-critical code."
        allowed_exceptions:
          - "one_time_initialization_allocation_with_bounded_memory_budget"
          - "project_approved_waiver_with_fragmentation_and_failure_analysis"
        detection_hints:
          c_cpp_patterns:
            - "malloc("
            - "calloc("
            - "realloc("
            - "free("
            - "new "
            - "delete "
          other_language_patterns:
            - "unbounded_runtime_allocation"
            - "unbounded_container_growth"
        failure_action: "block_in_safety_critical_profile"

      - id: "NASA-HR-002"
        title: "Use simple control flow"
        level: "should_for_high_reliability; must_for_safety_critical_profile"
        applies_to: ["source_code"]
        source_refs: ["NASA_SWEHB_CODING_STANDARDS#minimal_set", "JPL_POWER_OF_TEN#rule_1"]
        rule: "Avoid goto, setjmp, longjmp, and equivalent non-local jumps; avoid direct or indirect recursion."
        detection_hints:
          c_cpp_patterns:
            - "goto "
            - "setjmp("
            - "longjmp("
          graph_checks:
            - "recursive_call_graph"
        failure_action: "block_or_require_waiver"

      - id: "NASA-HR-003"
        title: "Bound loops statically"
        level: "should_for_high_reliability; must_for_safety_critical_profile"
        applies_to: ["loops"]
        source_refs: ["NASA_SWEHB_CODING_STANDARDS#minimal_set", "JPL_POWER_OF_TEN#rule_2"]
        rule: "Every loop must have a fixed upper bound provable by inspection or static analysis."
        allowed_exceptions:
          - "intentional nonterminating scheduler/control loop with documented invariant and watchdog/failsafe behavior"
        detection_hints:
          - "while_true_without_exit_contract"
          - "for_or_while_loop_without_max_iteration_bound"
          - "iteration_over_unbounded_external_input"
        failure_action: "block_in_safety_critical_profile"

      - id: "NASA-HR-004"
        title: "Declare data at the lowest possible scope"
        level: "should"
        applies_to: ["variables", "objects", "state"]
        source_refs: ["NASA_SWEHB_CODING_STANDARDS#minimal_set", "JPL_POWER_OF_TEN#rule_6"]
        rule: "Minimize variable/object scope; avoid unnecessary global or shared mutable state."
        detection_hints:
          - "global_mutable_state"
          - "module_level_state_without_justification"
          - "variable_declared_before_needed"
        failure_action: "warn_or_refactor"

      - id: "NASA-HR-005"
        title: "Validate function inputs"
        level: "should_for_high_reliability; must_for_safety_critical_profile"
        applies_to: ["public_functions", "boundary_crossing_functions", "safety_critical_functions"]
        source_refs: ["NASA_SWEHB_CODING_STANDARDS#minimal_set", "JPL_POWER_OF_TEN#rule_7"]
        rule: "Check validity/range of input parameters at function entry and handle off-nominal values explicitly."
        detection_hints:
          - "missing_null_check"
          - "missing_range_check"
          - "unchecked_external_input"
          - "unchecked_enum_or_state_value"
        failure_action: "block_for_boundary_or_safety_critical_code"

      - id: "NASA-HR-006"
        title: "Check non-void return values"
        level: "should_for_high_reliability; must_for_safety_critical_profile"
        applies_to: ["function_calls"]
        source_refs: ["NASA_SWEHB_CODING_STANDARDS#minimal_set", "JPL_POWER_OF_TEN#rule_7"]
        rule: "Every non-void return value must be used, checked, propagated, or explicitly discarded with justification."
        allowed_exceptions:
          - "explicit_void_cast_or_language_equivalent_with_comment"
          - "documented no-op-on-failure rationale"
        detection_hints:
          - "ignored_error_code"
          - "unchecked_result"
          - "discarded_future_or_promise"
        failure_action: "block_in_safety_critical_profile"

    JPL_POWER_OF_TEN_C_STRICT:
      - id: "JPL-P10-001"
        title: "Restrict to simple control flow"
        level: "must_in_safety_critical_c_profile"
        applies_to: ["C", "C++"]
        source_refs: ["JPL_POWER_OF_TEN#rule_1"]
        rule: "No goto, setjmp, longjmp, direct recursion, or indirect recursion."
        failure_action: "block"

      - id: "JPL-P10-002"
        title: "Fixed loop bounds"
        level: "must_in_safety_critical_c_profile"
        applies_to: ["C", "C++"]
        source_refs: ["JPL_POWER_OF_TEN#rule_2"]
        rule: "Every loop must have a statically provable preset upper bound."
        failure_action: "block"

      - id: "JPL-P10-003"
        title: "No dynamic allocation after initialization"
        level: "must_in_safety_critical_c_profile"
        applies_to: ["C", "C++"]
        source_refs: ["JPL_POWER_OF_TEN#rule_3"]
        rule: "No heap allocation/deallocation after initialization."
        failure_action: "block"

      - id: "JPL-P10-004"
        title: "Limit function size"
        level: "must_in_safety_critical_c_profile"
        applies_to: ["functions"]
        source_refs: ["JPL_POWER_OF_TEN#rule_4"]
        rule: "Keep each function to a single printed-page logical unit; target no more than about 60 source lines."
        metric:
          max_function_logical_lines: 60
        failure_action: "refactor_or_waive"

      - id: "JPL-P10-005"
        title: "Use meaningful assertions"
        level: "must_in_safety_critical_c_profile"
        applies_to: ["functions"]
        source_refs: ["JPL_POWER_OF_TEN#rule_5"]
        rule: "Average at least two meaningful, side-effect-free assertions per function, with explicit recovery on failure."
        constraints:
          assertions_side_effect_free: true
          assertions_must_not_be_tautologies: true
          failure_requires_recovery_action: true
        failure_action: "add_assertions_or_waive"

      - id: "JPL-P10-006"
        title: "Use smallest scope"
        level: "must_in_safety_critical_c_profile"
        applies_to: ["variables", "objects"]
        source_refs: ["JPL_POWER_OF_TEN#rule_6"]
        rule: "Declare data objects at the smallest possible scope."
        failure_action: "refactor"

      - id: "JPL-P10-007"
        title: "Check returns and parameters"
        level: "must_in_safety_critical_c_profile"
        applies_to: ["functions", "call_sites"]
        source_refs: ["JPL_POWER_OF_TEN#rule_7"]
        rule: "Check every non-void return value and validate every function parameter."
        failure_action: "block"

      - id: "JPL-P10-008"
        title: "Restrict preprocessor use"
        level: "must_in_safety_critical_c_profile"
        applies_to: ["C", "C++", "preprocessor"]
        source_refs: ["JPL_POWER_OF_TEN#rule_8"]
        rule: "Limit preprocessor use to header inclusion and simple macros; disallow token pasting, variadic macros, recursive macros, and unjustified conditional compilation."
        disallowed_patterns:
          - "##"
          - "__VA_ARGS__"
          - "recursive_macro"
          - "unjustified_#ifdef"
        failure_action: "block_or_require_waiver"

      - id: "JPL-P10-009"
        title: "Restrict pointers"
        level: "must_in_safety_critical_c_profile"
        applies_to: ["C", "C++"]
        source_refs: ["JPL_POWER_OF_TEN#rule_9"]
        rule: "Allow no more than one level of pointer dereferencing; do not hide dereference in macros or typedefs; disallow function pointers unless explicitly justified."
        failure_action: "block_or_require_waiver"

      - id: "JPL-P10-010"
        title: "Compile and statically analyze with zero warnings"
        level: "must_in_safety_critical_c_profile"
        applies_to: ["build", "ci", "static_analysis"]
        source_refs: ["JPL_POWER_OF_TEN#rule_10", "NASA_SWEHB_SWE_961#3.3"]
        rule: "Compile from day one with all warnings enabled at the most pedantic practical setting; code must compile and pass static analysis with zero unresolved warnings."
        required_evidence:
          - "compiler_warning_log"
          - "static_analyzer_log"
          - "warning_disposition_log"
        failure_action: "block_release"

  release_gates:
    required_artifacts:
      - "declared_coding_standard"
      - "static_analysis_report"
      - "secure_coding_static_analysis_report"
      - "compiler_warning_log"
      - "unit_test_results"
      - "coverage_report_or_applicability_note"
      - "complexity_report"
      - "peer_review_or_inspection_record_where_required"
      - "waiver_log"
      - "nonconformance_log"

    block_conditions:
      - "no_project_coding_standard"
      - "unresolved_static_analysis_error"
      - "unresolved_security_static_analysis_finding"
      - "unresolved_compiler_warning_in_safety_critical_profile"
      - "missing_unit_tests_for_changed_safety_critical_logic"
      - "unbounded_loop_in_safety_critical_profile"
      - "runtime_dynamic_allocation_in_safety_critical_profile_without_waiver"
      - "recursion_in_safety_critical_profile_without_waiver"
      - "unchecked_external_input_in_boundary_or_safety_critical_code"
      - "ignored_error_return_in_safety_critical_profile"

  agent_output_requirements:
    when_reviewing_code:
      include:
        - "profile_used"
        - "rules_checked"
        - "violations"
        - "evidence_missing"
        - "recommended_remediation"
        - "waivers_needed"
    when_generating_code:
      include:
        - "assumptions_about_profile"
        - "coding_standard_followed"
        - "known_unverified_items"
    prohibited_claims:
      - "NASA compliant"
      - "flight software ready"
      - "safety certified"
      - "secure by NASA standards"
    claim_allowed_only_if:
      - "project authority has selected/defined coding standard"
      - "all required evidence is present"
      - "tailoring/waivers are approved"
      - "the claim is scoped to the specific standard and software class"
