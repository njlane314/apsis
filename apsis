#!/bin/sh
set -eu

usage() {
    cat <<'EOF'
usage:
  apsis atlas ARGS...
  apsis bind ARGS...
  apsis doctor
  apsis dwell ARGS...
  apsis init --profile probe
  apsis probe ARGS...
  apsis trip ARGS...

shortcuts:
  apsis emit ARGS...       same as: atlas emit ARGS...
  apsis run ARGS...        same as: probe run ARGS...
  apsis attach ARGS...     same as: probe attach ARGS...
  apsis symbols ARGS...    same as: probe symbols ARGS...
  apsis plan ARGS...       same as: probe plan ARGS...
EOF
}

tool_dir=$(CDPATH= cd "$(dirname "$0")" && pwd)

find_tool() {
    tool=$1

    if [ -x "$tool_dir/$tool" ]; then
        printf '%s/%s\n' "$tool_dir" "$tool"
        return 0
    fi
    command -v "$tool"
}

run_tool() {
    tool=$1
    shift

    if [ -x "$tool_dir/$tool" ]; then
        exec "$tool_dir/$tool" "$@"
    fi
    exec "$tool" "$@"
}

doctor() {
    status=0

    printf 'apsis doctor\n'
    for tool in atlas bind dwell probe trip; do
        if path=$(find_tool "$tool" 2>/dev/null); then
            printf 'ok  %-6s %s\n' "$tool" "$path"
        else
            printf 'err %-6s not found\n' "$tool"
            status=1
        fi
    done

    if command -v "${CC:-cc}" >/dev/null 2>&1; then
        printf 'ok  cc     %s\n' "${CC:-cc}"
    else
        printf 'err cc     compiler not found\n'
        status=1
    fi

    if command -v make >/dev/null 2>&1; then
        printf 'ok  make   %s\n' "$(command -v make)"
    else
        printf 'err make   not found\n'
        status=1
    fi

    case "$(uname -s 2>/dev/null || printf unknown)" in
        Linux)
            printf 'ok  probe  Linux runtime available\n'
            ;;
        *)
            printf 'warn probe  runtime sampling is Linux-only\n'
            ;;
    esac

    return "$status"
}

write_probe_profile() {
    if [ -e telemetry.atlas ] || [ -e rules.trip ] || [ -e telemetry.bind ]; then
        printf 'apsis: refusing to overwrite existing probe profile files\n' >&2
        return 1
    fi

    cat > telemetry.atlas <<'EOF'
telemetry imu.temperature_c f32 C "IMU temperature"
limit imu.temperature_c > 80 warn imu.overtemp cooldown 5s

telemetry battery.voltage f32 V "Battery voltage"
limit battery.voltage < 10.8 error battery.low cooldown 5s
EOF

    cat > rules.trip <<'EOF'
imu.temperature_c > 80 warn imu.overtemp cooldown 5s
battery.voltage < 10.8 error battery.low cooldown 5s
EOF

    cat > telemetry.bind <<'EOF'
source imu.temperature_c f32 symbol imu_temperature_c
source battery.voltage f32 symbol battery_voltage
EOF

    printf 'created telemetry.atlas\n'
    printf 'created rules.trip\n'
    printf 'created telemetry.bind\n'
}

init_profile() {
    if [ "$#" -ne 2 ] || [ "$1" != "--profile" ]; then
        printf 'usage: apsis init --profile probe\n' >&2
        return 2
    fi

    case "$2" in
        probe)
            write_probe_profile
            ;;
        *)
            printf 'apsis: unknown profile %s\n' "$2" >&2
            return 2
            ;;
    esac
}

if [ "$#" -eq 0 ]; then
    usage
    exit 2
fi

case "$1" in
    -h|--help|help)
        usage
        exit 0
        ;;
    --version)
        printf '%s\n' 'apsis wrapper'
        exit 0
        ;;
    doctor)
        shift
        if [ "$#" -ne 0 ]; then
            printf 'usage: apsis doctor\n' >&2
            exit 2
        fi
        doctor
        ;;
    init)
        shift
        init_profile "$@"
        ;;
    atlas|bind|dwell|probe|trip)
        tool=$1
        shift
        run_tool "$tool" "$@"
        ;;
    emit)
        run_tool atlas "$@"
        ;;
    run|attach|symbols|plan)
        run_tool probe "$@"
        ;;
    *)
        printf 'apsis: unknown command %s\n' "$1" >&2
        usage >&2
        exit 2
        ;;
esac
